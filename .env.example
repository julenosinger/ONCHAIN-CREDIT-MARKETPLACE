# Arc Network
ARC_RPC_URL=https://your-arc-testnet-rpc
PRIVATE_KEY=0xyour_private_key
ARC_CHAIN_ID=5042002

# Real USDC token deployed on Arc Testnet
USDC_ADDRESS=0xYourArcUSDCAddress

# Contract verification (if explorer API supports)
ARC_EXPLORER_API_URL=https://explorer-api.arc.network/api
ARC_EXPLORER_BROWSER_URL=https://explorer.arc.network
ARC_EXPLORER_API_KEY=your_explorer_key

# Deployment ownership / roles
ADMIN_ADDRESS=0xYourAdminAddress
SCORER_ADDRESS=0xYourScorerAddress
DEFAULT_GRACE_PERIOD_SECONDS=259200
PLATFORM_MIN_SCORE=450

# Backend scoring engine
SCORING_LOOKBACK_BLOCKS=5000
DEFI_PROTOCOL_ADDRESSES=0xProtocolA,0xProtocolB
SCORE_EVIDENCE_BASE_URI=ipfs://
BACKEND_PORT=8787

# IPFS and privacy
IPFS_API_URL=https://ipfs.infura.io:5001/api/v0
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=
IPFS_GATEWAY=https://ipfs.io/ipfs
METADATA_ENCRYPTION_SECRET=change-this-secret

# Frontend
VITE_ARC_RPC_URL=https://your-arc-testnet-rpc
VITE_CHAIN_ID=5042002
VITE_USDC_ADDRESS=0xYourArcUSDCAddress
VITE_CREDIT_FACTORY=0x
VITE_CREDIT_TOKEN=0x
VITE_MARKETPLACE=0x
VITE_REPAYMENT_MANAGER=0x
VITE_CREDIT_SCORE=0x
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_BACKEND_URL=http://localhost:8787
