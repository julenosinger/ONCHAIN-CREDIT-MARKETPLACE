{
  "name": "onchain-credit-marketplace",
  "version": "1.0.0",
  "description": "Onchain Credit Marketplace on Arc Testnet",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf artifacts cache",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:arc": "hardhat run scripts/deploy.js --network arcTestnet",
    "verify:arc": "hardhat run scripts/verify.js --network arcTestnet",
    "export:abi": "node scripts/export-abi.js",
    "backend": "node backend/server.js",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev -- --host 0.0.0.0 --port 3000",
    "frontend:build": "cd frontend && npm run build"
  },
  "keywords": [
    "defi",
    "credit",
    "arc-network",
    "marketplace"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "dotenv": "^17.4.1",
    "hardhat": "^2.28.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ipfs-http-client": "^60.0.1",
    "multiformats": "^13.4.2",
    "viem": "^2.47.10",
    "zod": "^3.25.76"
  }
}
